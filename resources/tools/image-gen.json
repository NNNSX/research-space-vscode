{
  "id": "image-gen",
  "name": "图像生成",
  "description": "根据文字描述生成图像（GPT Image / Gemini / Doubao，需 AIHubMix Key）",
  "icon": "image",
  "supportsImages": false,
  "outputNodeType": "image",
  "apiType": "image_generation",
  "params": [
    {
      "name": "model",
      "type": "select",
      "label": "模型",
      "options": [
        "gemini-3-pro-image-preview",
        "gpt-image-2",
        "gemini-3.1-flash-image-preview",
        "doubao-seedream-5.0-lite"
      ],
      "default": ""
    },
    {
      "name": "prompt",
      "type": "text",
      "label": "图像描述",
      "default": ""
    },
    {
      "name": "aspect_ratio",
      "type": "select",
      "label": "画面比例",
      "options": [
        "1:1",
        "16:9",
        "9:16",
        "4:3",
        "3:4"
      ],
      "default": "1:1"
    },
    {
      "name": "size",
      "type": "select",
      "label": "输出尺寸",
      "options": [
        "2k",
        "3k",
        "1024x1024",
        "1024x1536",
        "1536x1024",
        "auto"
      ],
      "default": "2k"
    },
    {
      "name": "style_hint",
      "type": "text",
      "label": "风格提示（可选）",
      "default": ""
    },
    {
      "name": "web_search",
      "type": "boolean",
      "label": "启用联网检索（Doubao）",
      "default": false
    },
    {
      "name": "watermark",
      "type": "boolean",
      "label": "添加水印（Doubao）",
      "default": true
    },
    {
      "name": "quality",
      "type": "select",
      "label": "质量（GPT Image）",
      "options": [
        "high",
        "medium",
        "low",
        "auto"
      ],
      "default": "high"
    },
    {
      "name": "moderation",
      "type": "select",
      "label": "审核强度（GPT Image）",
      "options": [
        "low",
        "auto"
      ],
      "default": "low"
    },
    {
      "name": "background",
      "type": "select",
      "label": "背景（GPT Image）",
      "options": [
        "auto",
        "transparent",
        "opaque"
      ],
      "default": "auto"
    },
    {
      "name": "output_format",
      "type": "select",
      "label": "格式（GPT Image）",
      "options": [
        "png",
        "jpeg",
        "webp"
      ],
      "default": "png"
    },
    {
      "name": "n",
      "type": "number",
      "label": "张数（GPT Image）",
      "default": 1
    }
  ],
  "paramMaps": {},
  "systemPromptTemplate": "",
  "postProcessType": null,
  "category": "multimodal"
}
