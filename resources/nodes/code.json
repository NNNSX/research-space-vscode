{
  "id": "code",
  "label": "Code",
  "icon": "💻",
  "color": "var(--vscode-terminal-ansiCyan)",
  "extensions": [
    "py", "js", "ts", "tsx", "jsx",
    "rs", "go", "java", "c", "cpp",
    "cs", "rb", "swift", "kt", "r",
    "sh", "bash", "yaml", "yml", "json",
    "toml", "tex", "bib", "bst",
    "xml", "html", "css", "scss", "less",
    "sql", "graphql", "proto", "ini", "cfg",
    "env", "log", "conf"
  ],
  "previewType": "text",
  "watchContent": true,
  "contentExtractor": "text",
  "supportsMultimodal": false,
  "languageMap": {
    "py":   "python",
    "js":   "javascript",
    "ts":   "typescript",
    "tsx":  "typescript",
    "jsx":  "javascript",
    "rs":   "rust",
    "go":   "go",
    "java": "java",
    "c":    "c",
    "cpp":  "cpp",
    "cs":   "csharp",
    "rb":   "ruby",
    "swift":"swift",
    "kt":   "kotlin",
    "r":    "r",
    "sh":   "shell",
    "bash": "shell",
    "yaml": "yaml",
    "yml":  "yaml",
    "json": "json",
    "toml": "toml",
    "tex":  "latex",
    "bib":  "bibtex",
    "bst":  "bibtex",
    "xml":  "xml",
    "html": "html",
    "css":  "css",
    "scss": "scss",
    "less": "less",
    "sql":  "sql",
    "graphql": "graphql",
    "proto": "protobuf",
    "ini":  "ini",
